{
  "name": "antue",
  "version": "0.0.1",
  "description": "A set of enterprise-class Vue UI components, following the Ant Design specification.",
  "main": "dist/antue.js",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.examples.js",
    "site": "vite --config vite.config.site.js",
    "test": "jest",
    "lint": "eslint components/**/*.vue components/**/*.js components/**/*.jsx",
    "lint:fix": "eslint components/**/*.vue components/**/*.js components/**/*.jsx --fix",
    "build:examples": "vite build --config vite.config.examples.js",
    "build:site": "vite build --config vite.config.site.js",
    "build": "vite build --config vite.config.lib.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zzuu666/antue"
  },
  "bugs": {
    "url": "https://github.com/zzuu666/antue/issues"
  },
  "keywords": [
    "vue",
    "ant-design",
    "antue"
  ],
  "author": "zzuu666",
  "license": "MIT",
  "packageManager": "pnpm@8.15.4",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "less": "^4.2.0",
    "postcss": "^8.5.12",
    "vite": "^8.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "lodash.debounce": "^4.0.8",
    "moment": "^2.30.1"
  }
}
